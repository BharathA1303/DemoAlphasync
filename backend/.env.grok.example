# ────────────────────────────────────────────────────────────────
# AI MENTOR CONFIGURATION
# ────────────────────────────────────────────────────────────────
# Add your Grok API key from https://console.x.ai/
# Get API key: https://docs.x.ai/getting-started
GROK_API_KEY=xai_xxxxxxxxxxxxxxxxxxxx

# Example with actual format:
# GROK_API_KEY=xai_1234567890abcdef1234567890abcdef

# ────────────────────────────────────────────────────────────────
# In GitHub Actions, set this as a secret:
#   1. Go to repository Settings → Secrets and variables → Actions
#   2. Click "New repository secret"
#   3. Name: GROK_API_KEY
#   4. Value: Your actual Grok API key
#   5. Click "Add secret"
# ────────────────────────────────────────────────────────────────
