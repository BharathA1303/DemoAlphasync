# AlphaSync Environment Configuration Template
# Copy this to .env and fill in your actual values

# ═══════════════════════════════════════════════════════════════════════════════
# ZEBU MARKET DATA CONFIGURATION (REQUIRED FOR LIVE FUTURES/OPTIONS/COMMODITIES)
# ═══════════════════════════════════════════════════════════════════════════════

# Master Zebu Account - Provides live NSE data to ALL users without broker login
# Set this up for live market data to work (futures, options, commodities)
#
# Get these values from your MYNT (Zebu) account:
# 1. Go to: https://go.mynt.in/ (Zebu portal, rebranded to MYNT)
# 2. Login with your broker account
# 3. Navigate to: Client Dashboard → API Settings → App Creation
# 4. Create an API App to get credentials
#
ZEBU_MASTER_USER_ID=          # Your Zebu Client ID (e.g., FA12345)
ZEBU_MASTER_PASSWORD=         # Your Zebu login password
ZEBU_MASTER_DOB=             # Date of birth (DD-MM-YYYY) or TOTP code (6 digits)
ZEBU_API_SECRET=             # API Secret Key from MYNT portal (for QuickAuth)
ZEBU_VENDOR_CODE=            # Vendor ID (usually same as ZEBU_MASTER_USER_ID, or leave as user ID)

# WebSocket & REST API URLs (usually don't need to change)
ZEBU_WS_URL=wss://go.mynt.in/NorenWSTP/
ZEBU_API_URL=https://go.mynt.in/NorenWClientTP

# ═══════════════════════════════════════════════════════════════════════════════
# EXPECTED RESULTS WHEN CONFIGURED CORRECTLY
# ═══════════════════════════════════════════════════════════════════════════════
#
# ✅ WITH Master Zebu Session:
#    - Futures: Live contract list + live quotes from Zebu
#    - Options: Live chain data from NSE API
#    - Commodities: Live MCX prices from Zebu
#    - All users get live data without broker login
#
# ⚠️  WITHOUT Master Zebu Session (if you leave these blank):
#    - Futures: Fallback contract list (limited symbols only)
#    - Options: Still works (NSE API is public)
#    - Commodities: Simulated prices (realistic but not real)
#    - Users can still trade paper/virtual accounts
#
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: BROKER OAUTH (User-Initiated Broker Connection)
# ═══════════════════════════════════════════════════════════════════════════════

# Users can also connect their personal Zebu account via OAuth in the UI
# This provides per-user broker access and trading capabilities
ZEBU_REDIRECT_URI=http://localhost:5173/broker/callback

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

DATABASE_URL=postgresql+asyncpg://alphasync:alphasync@localhost:5432/alphasync
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ═══════════════════════════════════════════════════════════════════════════════
# REDIS CONFIGURATION (Live quote cache)
# ═══════════════════════════════════════════════════════════════════════════════

REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════════════════════════
# FIREBASE AUTHENTICATION
# ═══════════════════════════════════════════════════════════════════════════════

# Download your Firebase service account JSON from Firebase Console
# Options:
# 1. Set full JSON string:
FIREBASE_CREDENTIALS_JSON=

# 2. OR set path to JSON file:
FIREBASE_CREDENTIALS_PATH=

# ═══════════════════════════════════════════════════════════════════════════════
# ADMIN PANEL
# ═══════════════════════════════════════════════════════════════════════════════

ROOT_ADMIN_EMAIL=meganath1025@gmail.com
ADMIN_EMAIL_ALLOWLIST=meganath1025@gmail.com

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: SMS FOR OTP (Twilio)
# ═══════════════════════════════════════════════════════════════════════════════

# Leave blank to use email-only OTP
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ═══════════════════════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (Gmail SMTP)
# ═══════════════════════════════════════════════════════════════════════════════

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=         # Use Gmail App Password, not account password

# ═══════════════════════════════════════════════════════════════════════════════
# CORS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1):\d+

# ═══════════════════════════════════════════════════════════════════════════════
# APPLICATION CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

APP_NAME=AlphaSync
APP_VERSION=2.0.0
DEBUG=false

# Default virtual trading capital (in INR)
DEFAULT_VIRTUAL_CAPITAL=1000000.0

# ═══════════════════════════════════════════════════════════════════════════════
# TROUBLESHOOTING
# ═══════════════════════════════════════════════════════════════════════════════
#
# To verify configuration:
#
# 1. Start backend:
#    cd backend && python main.py
#
# 2. Check startup logs for:
#    "Master Zebu Session: ACTIVE" ✅ (if configured)
#    or "Master market data session: INACTIVE" ⚠️ (if not configured)
#
# 3. Call diagnostics endpoint:
#    curl http://localhost:8000/api/market/system/diagnostics
#
# 4. Look for:
#    - "master_zebu": { "active": true, ... }  ✅
#    - "Futures Contracts Available: 500+ total" ✅
#    - "NSE Options API: accessible" ✅
#
# ═══════════════════════════════════════════════════════════════════════════════
#
# Still having issues? Check:
# 1. ZEBU credentials are correct (copy-paste carefully from MYNT portal)
# 2. Zebu CDN URLs are reachable: ping go.mynt.in
# 3. Firewall/proxy allowing https://go.mynt.in and wss://go.mynt.in
# 4. Backend logs for "QuickAuth failed" or connection errors
# 5. NSE API accessibility: curl https://www.nseindia.com/api/
#
# ═══════════════════════════════════════════════════════════════════════════════
